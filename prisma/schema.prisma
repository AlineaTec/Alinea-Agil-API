  workspace_public_id     String?  @map("workspace_public_id")
  summary                 String
  payload_before          Json?    @map("payload_before")
  payload_after           Json?    @map("payload_after")

  @@index([occurred_at(sort: Desc)])
  @@index([target_platform_user_id, occurred_at(sort: Desc)])
  @@index([target_platform_tenant_id, occurred_at(sort: Desc)])
  @@index([workspace_public_id, occurred_at(sort: Desc)])
  @@index([actor_platform_user_id, occurred_at(sort: Desc)])
  @@map("platform_audit_events")
}

// -----------------------------------------------------------------------------
// Fase 15 — platform users / access / tenants
// -----------------------------------------------------------------------------

/// Usuario de plataforma (`/admin`, Mongo `platform_users`).
model PlatformUser {
  id                     String    @id @default(uuid()) @db.Uuid
  platform_user_id       String    @unique @map("platform_user_id")
  email                  String    @unique
  display_name           String?   @map("display_name")
  role                   String
  status                 String
  mfa_status             String    @map("mfa_status")
  mfa_totp_secret_base32 String?   @map("mfa_totp_secret_base32")
  mfa_failed_attempts    Int       @default(0) @map("mfa_failed_attempts")
  mfa_locked_until       DateTime? @map("mfa_locked_until")
  invitation_nonce_hash  String?   @map("invitation_nonce_hash")
  password_salt          String?   @map("password_salt")
  password_hash          String?   @map("password_hash")
  created_at             DateTime  @default(now()) @map("created_at")
  updated_at             DateTime  @updatedAt @map("updated_at")

  access_sessions       PlatformAccessSession[]
  password_reset_tokens PlatformPasswordResetToken[]

  @@map("platform_users")
}

/// Sesión de acceso plataforma (Mongo `platform_access_sessions`).
model PlatformAccessSession {
  id                String   @id @default(uuid()) @db.Uuid
  session_public_id String   @unique @map("session_public_id")
  platform_user_id  String   @map("platform_user_id")
  token_hash        String   @map("token_hash")
  expires_at        DateTime @map("expires_at")
  created_at        DateTime @default(now()) @map("created_at")
  updated_at        DateTime @updatedAt @map("updated_at")

  platform_user PlatformUser @relation(fields: [platform_user_id], references: [platform_user_id], onDelete: Cascade)

  @@index([token_hash])
  @@index([platform_user_id])
  @@index([expires_at])
  @@map("platform_access_sessions")
}

/// Token de reset de contraseña plataforma (Mongo `platform_password_reset_tokens`).
model PlatformPasswordResetToken {
  id               String    @id @default(uuid()) @db.Uuid
  token_hash       String    @unique @map("token_hash")
  platform_user_id String    @map("platform_user_id")
  email_normalized String    @map("email_normalized")
  expires_at       DateTime  @map("expires_at")
  used_at          DateTime? @map("used_at")
  created_at       DateTime  @default(now()) @map("created_at")
  updated_at       DateTime  @updatedAt @map("updated_at")

  platform_user PlatformUser @relation(fields: [platform_user_id], references: [platform_user_id], onDelete: Cascade)

  @@index([platform_user_id])
  @@index([expires_at])
  @@map("platform_password_reset_tokens")
}

/// Tenant plataforma 1:1 workspace (Mongo `platform_tenants`).
model PlatformTenant {
  id                  String   @id @default(uuid()) @db.Uuid
  platform_tenant_id  String   @unique @map("platform_tenant_id")
  workspace_id        String   @unique @db.Uuid @map("workspace_id")
  workspace_public_id String   @unique @map("workspace_public_id")
  status              String
  created_at          DateTime @default(now()) @map("created_at")
  updated_at          DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("platform_tenants")
}

// -----------------------------------------------------------------------------
// Fase 16 — transactional email outbound ledger
// -----------------------------------------------------------------------------

/// Ledger append-only de envíos transaccionales (Mongo `transactional_email_outbound_messages`).
model TransactionalEmailOutboundMessage {
  id                  String   @id @default(uuid()) @db.Uuid
  public_id           String   @unique @map("public_id")
  template_key        String   @map("template_key")
  to_normalized       String   @map("to_normalized")
  ok                  Boolean
  provider_message_id String?  @map("provider_message_id")
  error_message       String?  @map("error_message")
  created_at          DateTime @default(now()) @map("created_at")

  @@index([created_at(sort: Desc)])
  @@index([template_key])
  @@index([to_normalized])
  @@index([ok])
  @@map("transactional_email_outbound_messages")
}
