/// Configuración de flujo Kanban por proyecto (Mongo `project_kanban_flow_configs`).
model KanbanFlowConfig {
  id                      String   @id @default(uuid()) @db.Uuid
  workspace_id            String   @db.Uuid @map("workspace_id")
  workspace_public_id     String   @map("workspace_public_id")
  project_id              String   @unique @db.Uuid @map("project_id")
  project_public_id       String   @map("project_public_id")
  entry_column_public_id  String   @map("entry_column_public_id")
  wip_near_threshold_ratio Float?  @map("wip_near_threshold_ratio")
  /// Legacy: columnas migradas a `kanban_columns`. Se mantiene `schemaVersion` para trazabilidad.
  flow_definition         Json     @default("{\"schemaVersion\":2}") @map("flow_definition")
  created_at              DateTime @default(now()) @map("created_at")
  updated_at              DateTime @updatedAt @map("updated_at")

  workspace      Workspace      @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  project        Project        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  kanban_columns KanbanColumn[]

  @@unique([workspace_id, project_id])
  @@map("kanban_flow_configs")
}

/// Columna Kanban normalizada (fuente de verdad; antes en `flow_definition.columns[]`).
model KanbanColumn {
  id                      String   @id @default(uuid()) @db.Uuid
  public_id               String   @map("public_id")
  kanban_flow_config_id   String   @db.Uuid @map("kanban_flow_config_id")
  workspace_id            String   @db.Uuid @map("workspace_id")
  workspace_public_id     String   @map("workspace_public_id")
  project_id              String   @db.Uuid @map("project_id")
  project_public_id       String   @map("project_public_id")
  name                    String
  position                Int
  wip_limit               Int?     @map("wip_limit")
  policy_text             String   @default("") @map("policy_text")
  wip_enforcement         String   @map("wip_enforcement")
  created_at              DateTime @default(now()) @map("created_at")
  updated_at              DateTime @updatedAt @map("updated_at")

  kanban_flow_config KanbanFlowConfig @relation(fields: [kanban_flow_config_id], references: [id], onDelete: Cascade)
  workspace          Workspace        @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  project            Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  work_items         WorkItem[]

  @@unique([kanban_flow_config_id, public_id])
  @@unique([kanban_flow_config_id, position])
  @@index([project_id, public_id], map: "kanban_columns_project_public_id_idx")
  @@map("kanban_columns")
}

