// =============================================================================
// Alinea Ágil — esquema Prisma (PostgreSQL)
// =============================================================================
//
// Convenciones cerradas (ver docs/POSTGRESQL-SETUP.md):
//   • Tablas y columnas físicas: snake_case (@@map / @map)
//   • PK interna: id UUID
//   • public_id: cuando el recurso se expone por API o frontend
//   • created_at, updated_at en entidades persistentes de dominio
//   • jsonb solo cuando esté justificado; no para relaciones reales
//
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Fase 0 — infraestructura
// -----------------------------------------------------------------------------

/// Sonda técnica de infraestructura (Fase 0).
model InfrastructureConnectivityProbe {
  id         String   @id @default(uuid()) @db.Uuid
  probe_key  String   @unique @map("probe_key")
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@map("infrastructure_connectivity_probe")
}

// -----------------------------------------------------------------------------
// Fase 1 — dominio identity (usuarios registrados, sesión, registro, verificación)
// -----------------------------------------------------------------------------
// Nota: en Mongo la colección de usuarios es `identity_registered_users`; en
// PostgreSQL la tabla acordada es `identity_users` (mismo dominio, nombre nuevo).
// -----------------------------------------------------------------------------

enum IdentityRegistrationIntentStatus {
  EMAIL_COLLECTED
  EMAIL_VERIFIED
  MODALITY_SELECTED
  WORKSPACE_PROPOSED
  CREDENTIALS_SET
  PAYMENT_PENDING
  PAYMENT_FAILED
  PAYMENT_SUCCEEDED
  PROVISIONING
  ACTIVE
  EXPIRED
  ABANDONED

  @@map("identity_registration_intent_status")
}

enum IdentityVerificationChallengeStatus {
  PENDING
  CONSUMED
  EXPIRED
  SUPERSEDED

  @@map("identity_verification_challenge_status")
}

enum IdentityBillingCadence {
  monthly
  annual

  @@map("identity_billing_cadence")
}

/// Usuario registrado tras activación (equivalente Mongo `identity_registered_users`).
model IdentityUser {
  id                                    String   @id @default(uuid()) @db.Uuid
  public_id                             String   @unique @map("public_id")
  email_normalized                      String   @unique @map("email_normalized")
  full_name                             String   @map("full_name")
  password_hash                         String   @map("password_hash")
  modality_at_signup                    String   @map("modality_at_signup")
  source_registration_intent_public_id  String   @map("source_registration_intent_public_id")
  preferred_active_workspace_public_id String?  @map("preferred_active_workspace_public_id")
  preferred_active_workspace_updated_at DateTime? @map("preferred_active_workspace_updated_at")
  created_at                            DateTime @default(now()) @map("created_at")
  updated_at                            DateTime @updatedAt @map("updated_at")

  source_registration_intent IdentityRegistrationIntent @relation("UserSourceIntent", fields: [source_registration_intent_public_id], references: [public_id])
  auth_sessions              IdentityAuthSession[]
  password_reset_tokens      IdentityPasswordResetToken[]
  workspace_owner_memberships WorkspaceOwnerMembership[]
  workspace_members          WorkspaceMember[]
  work_item_time_entries     WorkItemTimeEntry[]
  notifications_received     WorkActivityNotification[] @relation("NotificationRecipient")
  work_item_implicit_follows WorkItemImplicitFollow[] @relation("WorkItemFollower")
  daily_alignment_participant_updates DailyAlignmentParticipantUpdate[] @relation("DailyParticipant")
  guided_review_feedback_entries GuidedReviewFeedbackEntry[] @relation("ReviewFeedbackAuthor")
  guided_retrospective_topics_created GuidedRetrospectiveTopic[] @relation("RetroTopicCreator")
  guided_retrospective_votes_cast GuidedRetrospectiveVote[] @relation("RetroVoter")
  guided_retrospective_action_items_owned GuidedRetrospectiveActionItem[] @relation("RetroActionOwner")
  reported_impediments              ProjectImpediment[] @relation("ImpedimentReporter")
  responsible_impediments         ProjectImpediment[] @relation("ImpedimentResponsible")
  impediment_comments_authored    ProjectImpedimentComment[] @relation("ImpedimentCommentAuthor")
  work_control_override_tokens    WorkControlOverrideToken[] @relation("OverrideTokenActor")

  @@index([source_registration_intent_public_id])
  @@map("identity_users")
}

/// Sesión Bearer persistida (`identity_auth_sessions`).
model IdentityAuthSession {
  id         String   @id @default(uuid()) @db.Uuid
  public_id  String   @unique @map("public_id")
  user_id    String   @db.Uuid @map("user_id")
  token_hash String   @map("token_hash")
  expires_at DateTime @map("expires_at")
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  user IdentityUser @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
  @@index([expires_at])
  @@map("identity_auth_sessions")
}

/// Token opaco de restablecimiento de contraseña (solo hash en BD).
model IdentityPasswordResetToken {
  id               String    @id @default(uuid()) @db.Uuid
  token_hash       String    @unique @map("token_hash")
  user_id          String    @db.Uuid @map("user_id")
  email_normalized String    @map("email_normalized")
  expires_at       DateTime  @map("expires_at")
  used_at          DateTime? @map("used_at")
  created_at       DateTime  @default(now()) @map("created_at")
  updated_at       DateTime  @updatedAt @map("updated_at")

  user IdentityUser @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@index([used_at])
  @@map("identity_password_reset_tokens")
}

/// Intento de registro público (`identity_registration_intents`).
model IdentityRegistrationIntent {
  id                              String                            @id @default(uuid()) @db.Uuid
  public_id                       String                            @unique @map("public_id")
  email_normalized                String                            @map("email_normalized")
  status                          IdentityRegistrationIntentStatus
  modality                        String?
  billing_cadence                 IdentityBillingCadence?
  team_seats_purchased            Int?
  workspace_display_name          String?                           @map("workspace_display_name")
  workspace_code                  String?                           @map("workspace_code")
  account_full_name               String?                           @map("account_full_name")
  password_hash                   String?                           @map("password_hash")
  provisioned_user_public_id      String?                           @map("provisioned_user_public_id")
  provisioned_workspace_public_id String?                           @map("provisioned_workspace_public_id")
  provisioned_at                  DateTime?                         @map("provisioned_at")
  plan_sku                        String?                           @map("plan_sku")
  payment_provider_ref            String?                           @map("payment_provider_ref")
  metadata                        Json                              @default("{}") @map("metadata")
  expires_at                      DateTime                          @map("expires_at")
  created_at                      DateTime                          @default(now()) @map("created_at")
  updated_at                      DateTime                          @updatedAt @map("updated_at")

  verification_challenges IdentityVerificationChallenge[]
  registered_users        IdentityUser[]                  @relation("UserSourceIntent")
  workspaces              Workspace[]

  @@index([email_normalized])
  @@index([expires_at])
  @@index([provisioned_user_public_id])
  @@index([provisioned_workspace_public_id])
  @@unique([workspace_code])
  @@map("identity_registration_intents")
}

/// Desafío OTP de verificación de email en registro.
model IdentityVerificationChallenge {
  id                              String                            @id @default(uuid()) @db.Uuid
  public_id                       String                            @unique @map("public_id")
  registration_intent_id          String                            @db.Uuid @map("registration_intent_id")
  registration_intent_public_id   String                            @map("registration_intent_public_id")
  email_normalized                String                            @map("email_normalized")
  code_hash                       String                            @map("code_hash")
  status                          IdentityVerificationChallengeStatus
  expires_at                      DateTime                          @map("expires_at")
  attempt_count                   Int                               @default(0) @map("attempt_count")
  max_attempts                    Int                               @default(5) @map("max_attempts")
  created_at                      DateTime                          @default(now()) @map("created_at")
  updated_at                      DateTime                          @updatedAt @map("updated_at")

  registration_intent IdentityRegistrationIntent @relation(fields: [registration_intent_id], references: [id], onDelete: Cascade)

  @@index([registration_intent_id])
  @@index([registration_intent_public_id])
  @@index([email_normalized])
  @@index([expires_at])
  @@map("identity_verification_challenges")
}

// -----------------------------------------------------------------------------
// Fase 2 — dominio workspace y organización
// -----------------------------------------------------------------------------
// Nota: en Mongo el tenant se persiste en `workspace_records`; en PostgreSQL la
// tabla acordada es `workspaces`. Owner membership ≠ workspace_members (ver docs).
// `work_team_project_links.project_public_id` es referencia blanda (projects no migrado).
// -----------------------------------------------------------------------------

enum WorkspaceOwnerMembershipRole {
  owner

  @@map("workspace_owner_membership_role")
}

enum WorkspaceMemberStatus {
  pending
  active
  active_without_seat
  deactivated

  @@map("workspace_member_status")
}

enum WorkspaceInvitationStatus {
  pending
  accepted
  expired
  revoked
  superseded

  @@map("workspace_invitation_status")
}

enum WorkTeamStatus {
  active
  inactive
  archived

  @@map("work_team_status")
}

enum WorkspaceBillingCadence {
  monthly
  annual

  @@map("workspace_billing_cadence")
}

/// Tenant workspace (equivalente Mongo `workspace_records`).
model Workspace {
  id                                    String                   @id @default(uuid()) @db.Uuid
  public_id                             String                   @unique @map("public_id")
  slug                                  String                   @unique @map("slug")
  display_name                          String                   @map("display_name")
  modality                              String
  billing_cadence                       WorkspaceBillingCadence?
  source_registration_intent_public_id  String                   @map("source_registration_intent_public_id")
  created_at                            DateTime                 @default(now()) @map("created_at")
  updated_at                            DateTime                 @updatedAt @map("updated_at")

  source_registration_intent IdentityRegistrationIntent @relation(fields: [source_registration_intent_public_id], references: [public_id])
  owner_memberships            WorkspaceOwnerMembership[]
  members                      WorkspaceMember[]
  invitations                  WorkspaceInvitation[]
  license                      WorkspaceLicense?
  work_teams                   WorkTeam[]
  project_drafts               ProjectDraft[]
  projects                     Project[]
  work_items                   WorkItem[]
  work_activity_notifications  WorkActivityNotification[]
  work_item_implicit_follows   WorkItemImplicitFollow[]
  sprints                      Sprint[]
  sprint_assignments           SprintAssignment[]
  guided_sprint_planning_sessions GuidedSprintPlanningSession[]
  kanban_flow_configs          KanbanFlowConfig[]
  daily_alignment_sessions     DailyAlignmentSession[]
  guided_refinement_sessions   GuidedRefinementSession[]
  guided_review_sessions       GuidedReviewSession[]
  guided_retrospective_sessions GuidedRetrospectiveSession[]
  project_impediments           ProjectImpediment[]
  impediment_comments           ProjectImpedimentComment[]
  work_controls_templates       WorkControlsWorkspaceTemplate?
  work_controls_project_profiles WorkControlsProjectProfile[]
  work_control_override_tokens  WorkControlOverrideToken[]
  billing_snapshot              BillingWorkspaceSnapshot?
  billing_notification_sends    BillingNotificationSend[]
  billing_workspace_audit_events BillingWorkspaceAuditEvent[]
  payment_receipts              PaymentWorkspaceReceipt[]
  workspace_audit_events        WorkspaceAuditEvent[]
  work_team_audit_events        WorkTeamAuditEvent[]
  product_feedback_submissions  ProductFeedbackSubmission[]
  product_idea_feedback_entries ProductIdeaFeedbackEntry[]
  product_feedback_audit_events ProductFeedbackAuditEvent[]
  product_idea_feedback_audit_events ProductIdeaFeedbackAuditEvent[]
  operating_snapshot_nba_snoozes     ProjectOperatingSnapshotNbaSnooze[]
  platform_tenant                      PlatformTenant?
  kanban_columns                       KanbanColumn[]

  @@index([source_registration_intent_public_id])
  @@map("workspaces")
}

/// Vínculo de provisioning del owner inicial (no sustituye a `workspace_members`).
model WorkspaceOwnerMembership {
  id                 String                       @id @default(uuid()) @db.Uuid
  public_id          String                       @unique @map("public_id")
  workspace_id       String                       @db.Uuid @map("workspace_id")
  user_public_id     String                       @map("user_public_id")
  role               WorkspaceOwnerMembershipRole
  created_at         DateTime                     @default(now()) @map("created_at")
  updated_at         DateTime                     @updatedAt @map("updated_at")

  workspace Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      IdentityUser @relation(fields: [user_public_id], references: [public_id])

  @@unique([workspace_id, user_public_id])
  @@index([user_public_id])
  @@map("workspace_owner_memberships")
}

/// Membresía operativa del workspace (miembros, asientos, roles).
model WorkspaceMember {
  id                            String                @id @default(uuid()) @db.Uuid
  public_id                     String                @unique @map("public_id")
  workspace_id                  String                @db.Uuid @map("workspace_id")
  workspace_public_id           String                @map("workspace_public_id")
  user_public_id                String                @map("user_public_id")
  email_normalized              String                @map("email_normalized")
  full_name                     String                @map("full_name")
  status                        WorkspaceMemberStatus
  has_seat_assigned             Boolean               @map("has_seat_assigned")
  workspace_role_administrative String?               @map("workspace_role_administrative")
  workspace_role_methodological String?               @map("workspace_role_methodological")
  created_at                    DateTime              @default(now()) @map("created_at")
  updated_at                    DateTime              @updatedAt @map("updated_at")

  workspace Workspace    @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      IdentityUser @relation(fields: [user_public_id], references: [public_id])

  @@unique([workspace_id, email_normalized])
  @@unique([workspace_id, user_public_id])
  @@index([user_public_id])
  @@map("workspace_members")
}

/// Invitación pendiente o histórica a un workspace.
model WorkspaceInvitation {
  id                                String                    @id @default(uuid()) @db.Uuid
  public_id                         String                    @unique @map("public_id")
  workspace_id                      String                    @db.Uuid @map("workspace_id")
  workspace_public_id               String                    @map("workspace_public_id")
  email_normalized                  String                    @map("email_normalized")
  full_name_proposed                String                    @map("full_name_proposed")
  workspace_role_administrative     String?                   @map("workspace_role_administrative")
  workspace_role_methodological     String?                   @map("workspace_role_methodological")
  assign_seat_proposal              Boolean                   @map("assign_seat_proposal")
  token_hash                        String                    @unique @map("token_hash")
  status                            WorkspaceInvitationStatus
  expires_at                        DateTime                  @map("expires_at")
  invited_by_user_public_id         String                    @map("invited_by_user_public_id")
  accepted_at                       DateTime?                 @map("accepted_at")
  revoked_at                        DateTime?                 @map("revoked_at")
  superseded_by_invitation_public_id String?                  @map("superseded_by_invitation_public_id")
  email_comms_sent_at               DateTime?                 @map("email_comms_sent_at")
  created_at                        DateTime                  @default(now()) @map("created_at")
  updated_at                        DateTime                  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, email_normalized])
  @@index([workspace_id, status])
  @@index([expires_at])
  @@map("workspace_invitations")
}

/// Licencia de asientos por workspace (1:1 con workspace).
model WorkspaceLicense {
  id                              String    @id @default(uuid()) @db.Uuid
  workspace_id                    String    @unique @db.Uuid @map("workspace_id")
  workspace_public_id             String    @unique @map("workspace_public_id")
  seats_purchased                 Int       @map("seats_purchased")
  seats_assigned                  Int       @map("seats_assigned")
  pending_reduction_target_purchased Int?   @map("pending_reduction_target_purchased")
  pending_reduction_applies_on    DateTime? @map("pending_reduction_applies_on")
  next_renewal_date               DateTime  @map("next_renewal_date")
  last_renewal_at                 DateTime? @map("last_renewal_at")
  created_at                      DateTime  @default(now()) @map("created_at")
  updated_at                      DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("workspace_licenses")
}

/// Equipo de trabajo dentro de un workspace.
model WorkTeam {
  id                      String         @id @default(uuid()) @db.Uuid
  public_id               String         @unique @map("public_id")
  workspace_id            String         @db.Uuid @map("workspace_id")
  workspace_public_id     String         @map("workspace_public_id")
  name                    String
  name_normalized         String         @map("name_normalized")
  description             String?
  status                  WorkTeamStatus
  team_lead_user_public_id String?       @map("team_lead_user_public_id")
  target_size             Int?           @map("target_size")
  created_at              DateTime       @default(now()) @map("created_at")
  updated_at              DateTime       @updatedAt @map("updated_at")

  workspace      Workspace              @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  memberships    WorkTeamMembership[]
  project_links  WorkTeamProjectLink[]

  @@unique([workspace_id, name_normalized])
  @@index([workspace_public_id])
  @@map("work_teams")
}

/// Membresía de usuario en un equipo.
model WorkTeamMembership {
  id                      String    @id @default(uuid()) @db.Uuid
  public_id               String    @unique @map("public_id")
  workspace_id            String    @db.Uuid @map("workspace_id")
  workspace_public_id     String    @map("workspace_public_id")
  team_id                 String    @db.Uuid @map("team_id")
  team_public_id          String    @map("team_public_id")
  user_public_id          String    @map("user_public_id")
  joined_at               DateTime  @map("joined_at")
  left_at                 DateTime? @map("left_at")
  is_active               Boolean   @map("is_active")
  created_at              DateTime  @default(now()) @map("created_at")
  updated_at              DateTime  @updatedAt @map("updated_at")

  team WorkTeam @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@index([team_id, is_active])
  @@index([workspace_id, user_public_id])
  @@map("work_team_memberships")
}

/// Enlace equipo ↔ proyecto (FK a `projects`; `project_public_id` denormalizado para consultas).
model WorkTeamProjectLink {
  id                  String   @id @default(uuid()) @db.Uuid
  public_id           String   @unique @map("public_id")
  workspace_id        String   @db.Uuid @map("workspace_id")
  workspace_public_id String   @map("workspace_public_id")
  team_id             String   @db.Uuid @map("team_id")
  team_public_id      String   @map("team_public_id")
  project_id          String   @db.Uuid @map("project_id")
  project_public_id   String   @map("project_public_id")
  created_at          DateTime @default(now()) @map("created_at")
  updated_at          DateTime @updatedAt @map("updated_at")

  team    WorkTeam  @relation(fields: [team_id], references: [id], onDelete: Cascade)
  project Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([team_id, project_id])
  @@index([workspace_id, project_public_id])
  @@map("work_team_project_links")
}

// -----------------------------------------------------------------------------
// Fase 3 — projects y work items
// -----------------------------------------------------------------------------
// Mongo: `workspace_project_drafts` → `project_drafts`; `workspace_runtime_projects` → `projects`;
// `project_scrum_backlog_items` → `work_items` (tabla unificada).
// -----------------------------------------------------------------------------

enum ProjectDraftStatus {
  definition_in_progress
  ready_for_assessment
  assessment_in_progress
  ready_for_recommendation
  recommended
  decision_recorded
  materialized
  not_ready_complete

  @@map("project_draft_status")
}

enum ProjectOperationalApproach {
  scrum
  kanban
  predictive_phases

  @@map("project_operational_approach")
}

enum ProjectLifecycleStatus {
  active
  archived

  @@map("project_lifecycle_status")
}

enum WorkItemType {
  epic
  user_story
  task
  subtask
  bug

  @@map("work_item_type")
}

enum WorkItemStatus {
  open
  in_progress
  done

  @@map("work_item_status")
}

enum WorkItemPriorityLevel {
  none
  low
  medium
  high
  urgent

  @@map("work_item_priority_level")
}

/// Borrador de proyecto (Mongo `workspace_project_drafts`).
model ProjectDraft {
  id                           String            @id @default(uuid()) @db.Uuid
  public_id                    String            @unique @map("public_id")
  workspace_id                 String            @db.Uuid @map("workspace_id")
  workspace_public_id          String            @map("workspace_public_id")
  created_by_user_public_id    String            @map("created_by_user_public_id")
  status                       ProjectDraftStatus
  project_name                 String            @map("project_name")
  charter                      Json              @default("{}")
  methodology_assessment       Json              @default("{}") @map("methodology_assessment")
  recommendation_result        Json?             @map("recommendation_result")
  selected_approach            String?           @map("selected_approach")
  was_recommendation_overridden Boolean?         @map("was_recommendation_overridden")
  override_justification       String?           @map("override_justification")
  materialized_project_public_id String?         @map("materialized_project_public_id")
  trace                        Json              @default("[]")
  materialization              Json              @default("{\"status\":\"none\",\"materializedProjectPublicId\":null}")
  created_at                   DateTime          @default(now()) @map("created_at")
  updated_at                   DateTime          @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  projects  Project[] @relation("ProjectSourceDraft")

  @@index([workspace_id, updated_at])
  @@map("project_drafts")
}

/// Proyecto operativo materializado (Mongo `workspace_runtime_projects`).
model Project {
  id                            String                   @id @default(uuid()) @db.Uuid
  public_id                     String                   @unique @map("public_id")
  workspace_id                  String                   @db.Uuid @map("workspace_id")
  workspace_public_id           String                   @map("workspace_public_id")
  source_draft_public_id        String                   @map("source_draft_public_id")
  project_name                  String                   @map("project_name")
  operational_approach          ProjectOperationalApproach @map("operational_approach")
  initial_configuration_summary Json                     @default("{}") @map("initial_configuration_summary")
  lifecycle_status              ProjectLifecycleStatus   @map("lifecycle_status")
  materialized_at               DateTime                 @map("materialized_at")
  created_at                    DateTime                 @default(now()) @map("created_at")
  updated_at                    DateTime                 @updatedAt @map("updated_at")

  workspace            Workspace              @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  source_draft         ProjectDraft           @relation("ProjectSourceDraft", fields: [source_draft_public_id], references: [public_id])
  work_items                 WorkItem[]
  team_project_links         WorkTeamProjectLink[]
  work_activity_notifications WorkActivityNotification[]
  sprints                    Sprint[]
  sprint_assignments         SprintAssignment[]
  guided_sprint_planning_sessions GuidedSprintPlanningSession[]
  guided_sprint_planning_baselines GuidedSprintPlanningBaseline[]
  kanban_flow_config         KanbanFlowConfig?
  daily_alignment_sessions   DailyAlignmentSession[]
  guided_refinement_sessions GuidedRefinementSession[]
  guided_review_sessions     GuidedReviewSession[]
  guided_retrospective_sessions GuidedRetrospectiveSession[]
  guided_retrospective_action_items GuidedRetrospectiveActionItem[]
  impediments                   ProjectImpediment[]
  impediment_comments           ProjectImpedimentComment[]
  work_controls_profiles        WorkControlsProjectProfile[]
  work_control_override_tokens  WorkControlOverrideToken[]
  impediment_audit_events       ProjectImpedimentAuditEvent[]
  product_feedback_submissions  ProductFeedbackSubmission[]
  product_idea_feedback_entries ProductIdeaFeedbackEntry[]
  operating_snapshot_nba_snoozes ProjectOperatingSnapshotNbaSnooze[]
  kanban_columns                 KanbanColumn[]

  @@unique([workspace_id, public_id])
  @@unique([workspace_id, source_draft_public_id])
  @@index([workspace_id, updated_at(sort: Desc)], map: "projects_workspace_updated_idx")
  @@map("projects")
}

/// Ítem de trabajo unificado (Mongo `project_scrum_backlog_items`).
model WorkItem {
  id                              String              @id @default(uuid()) @db.Uuid
  public_id                       String              @unique @map("public_id")
  workspace_id                    String              @db.Uuid @map("workspace_id")
  workspace_public_id             String              @map("workspace_public_id")
  project_id                      String              @db.Uuid @map("project_id")
  project_public_id               String              @map("project_public_id")
  parent_item_id                  String?             @db.Uuid @map("parent_item_id")
  item_type                       WorkItemType        @map("item_type")
  title                           String
