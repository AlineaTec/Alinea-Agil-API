// -----------------------------------------------------------------------------
// Fase 4 — dominio Scrum/Kanban operativo
// -----------------------------------------------------------------------------

enum ScrumSprintStatus {
  planning
  ready_for_execution
  active
  closed

  @@map("scrum_sprint_status")
}

enum GuidedSprintPlanningSessionStatus {
  open
  closed
  closed_with_warnings
  closed_without_baseline

  @@map("guided_sprint_planning_session_status")
}

/// Ciclo operativo Scrum (Mongo `project_scrum_sprints`).
model Sprint {
  id                      String            @id @default(uuid()) @db.Uuid
  public_id               String            @unique @map("public_id")
  workspace_id            String            @db.Uuid @map("workspace_id")
  workspace_public_id     String            @map("workspace_public_id")
  project_id              String            @db.Uuid @map("project_id")
  project_public_id       String            @map("project_public_id")
  name                    String
  goal                    String            @default("")
  status                  ScrumSprintStatus
  start_date              DateTime?         @map("start_date")
  end_date                DateTime?         @map("end_date")
  created_by_user_public_id String          @map("created_by_user_public_id")
  closure                 Json?             @map("closure")
  review                  Json?             @map("review")
  retrospective           Json?             @map("retrospective")
  created_at              DateTime          @default(now()) @map("created_at")
  updated_at              DateTime          @updatedAt @map("updated_at")

  workspace  Workspace         @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  project    Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignments SprintAssignment[]
  guided_planning_sessions GuidedSprintPlanningSession[]
  guided_planning_baselines GuidedSprintPlanningBaseline[]
  daily_alignment_sessions DailyAlignmentSession[] @relation("SprintDailyAlignment")
  guided_refinement_sessions GuidedRefinementSession[] @relation("SprintRefinement")
  guided_review_sessions GuidedReviewSession[] @relation("SprintReview")
  guided_retrospective_sessions GuidedRetrospectiveSession[] @relation("SprintRetrospective")
  work_items_completed_here     WorkItem[]                   @relation("WorkItemCompletedInSprint")
  related_impediments           ProjectImpediment[]          @relation("ImpedimentRelatedSprint")

  @@unique([workspace_id, project_id, public_id])
  @@index([workspace_id, project_id, status], map: "sprints_workspace_project_status_idx")
  @@map("sprints")
}

/// Vínculo sprint ↔ work_item (Mongo `project_scrum_sprint_assignments`).
model SprintAssignment {
  id                        String   @id @default(uuid()) @db.Uuid
  workspace_id              String   @db.Uuid @map("workspace_id")
  workspace_public_id       String   @map("workspace_public_id")
  project_id                String   @db.Uuid @map("project_id")
  project_public_id         String   @map("project_public_id")
  sprint_id                 String   @db.Uuid @map("sprint_id")
  sprint_public_id          String   @map("sprint_public_id")
  work_item_id              String   @db.Uuid @map("work_item_id")
  work_item_public_id       String   @map("work_item_public_id")
  sprint_sort_order         Int      @map("sprint_sort_order")
  committed_at              DateTime @map("committed_at")
  committed_by_user_public_id String @map("committed_by_user_public_id")
  board_column              String?  @map("board_column")

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  sprint    Sprint    @relation(fields: [sprint_id], references: [id], onDelete: Cascade)
  work_item WorkItem  @relation(fields: [work_item_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, project_id, sprint_id, work_item_id])
  @@index([workspace_id, project_id, work_item_id], map: "sprint_assignments_by_work_item_idx")
  @@index([workspace_id, project_id, sprint_id, sprint_sort_order], map: "sprint_assignments_sprint_order_idx")
  @@map("sprint_assignments")
}

