  session_id                  String   @unique @db.Uuid @map("session_id")
  session_public_id           String   @unique @map("session_public_id")
  workspace_id                String   @db.Uuid @map("workspace_id")
  workspace_public_id         String   @map("workspace_public_id")
  project_id                  String   @db.Uuid @map("project_id")
  project_public_id           String   @map("project_public_id")
  sprint_id                   String?  @db.Uuid @map("sprint_id")
  sprint_public_id            String?  @map("sprint_public_id")
  sprint_goal                 String?  @map("sprint_goal")
  committed_work_item_public_ids String[] @default([]) @map("committed_work_item_public_ids")
