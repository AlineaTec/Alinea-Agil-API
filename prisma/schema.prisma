  follow_ups                  String[]                          @default([]) @map("follow_ups")
  capacity_total              Int?                              @map("capacity_total")
  capacity_unit               String?                           @map("capacity_unit")
  buffer_reserved             Int?                              @map("buffer_reserved")
  buffer_mode                 String?                           @map("buffer_mode")
  candidate_item_count        Int                               @default(0) @map("candidate_item_count")
  committed_item_count        Int                               @default(0) @map("committed_item_count")
  excluded_item_count         Int                               @default(0) @map("excluded_item_count")
  pending_decision_count      Int                               @default(0) @map("pending_decision_count")
  planning_warnings           String[]                          @default([]) @map("planning_warnings")
  baseline_created            Boolean                           @default(false) @map("baseline_created")
