  project_id                  String                            @db.Uuid @map("project_id")
  project_public_id           String                            @map("project_public_id")
  sprint_id                   String?                           @db.Uuid @map("sprint_id")
  sprint_public_id            String?                           @map("sprint_public_id")
  session_date                String                            @map("session_date")
  session_slot                String                            @map("session_slot")
  operational_approach        String                            @map("operational_approach")
  operational_time_zone       String                            @map("operational_time_zone")
  planning_mode               String                            @map("planning_mode")
  facilitator_user_public_id  String?                           @map("facilitator_user_public_id")
  product_owner_user_public_id String?                           @map("product_owner_user_public_id")
  status                      GuidedSprintPlanningSessionStatus
