  @@index([workspace_id, project_id, updated_at], map: "guided_sprint_planning_sessions_project_updated_idx")
  @@map("guided_sprint_planning_sessions")
}

/// Candidato de planning (Mongo `guided_sprint_planning_candidate_items`).
model GuidedSprintPlanningCandidateItem {
