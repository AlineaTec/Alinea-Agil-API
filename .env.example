# =============================================================================
#  API — ejemplo de variables de entorno
# =============================================================================
#
#  Uso:
#    cp .env.example .env
#    Edita `.env`; se carga con `import "dotenv/config"` al arrancar (`server.ts`).
#
#  Documentación relacionada:
#    • Seguridad en prod (Turnstile, CORS, Helmet): README.md (este paquete `api`)
#    • Módulos: src/modules/*/README.md y contracts-docs/docs/modules/
#
#  Convención en este fichero:
#    • Líneas sin `#` al inicio = valores por defecto razonables para desarrollo local.
#    • Líneas `# VARIABLE=...` = opcionales o solo ciertos entornos; descomenta si aplica.
#
# =============================================================================


# -----------------------------------------------------------------------------
#  Servidor y base de datos (PostgreSQL único)
# -----------------------------------------------------------------------------
# Obligatoria. Ver docs/POSTGRESQL-MIGRATION-CLOSURE.md y npm run postgres:migrate:deploy
DATABASE_URL=postgresql://alinea:alinea_dev@localhost:5432/alinea_agil?schema=public
PORT=3000

# Tests de integración Postgres (opcional; si no se define, Testcontainers + Docker):
# DATABASE_URL_TEST=postgresql://alinea:alinea_dev@localhost:5432/alinea_agil_test?schema=public
# POSTGRES_TEST_USE_ENV=1

# Seed local (npm run db:reset:* / seed:*) — obligatorio ALLOW_DB_SEED=1 al ejecutar.
# Valores por defecto en src/scripts/seed/shared/credentials.ts si omites estas variables.
# ALLOW_DB_SEED=1
# SEED_PLATFORM_PASSWORD=   # admin plataforma agil@alineatec.com
# SEED_USER_PASSWORD=        # usuarios workspace (demo: pruebas@alineatec.com y equipo)


# -----------------------------------------------------------------------------
#  Logs
# -----------------------------------------------------------------------------
# En Vercel el formato suele ser una línea JSON por evento (arranque y http.request).
# En otros hosts puedes unificar el formato:
# LOG_FORMAT=json


# -----------------------------------------------------------------------------
#  Entorno de ejecución (clasificación del despliegue)
# -----------------------------------------------------------------------------
# Afecta a Sentry, política de pasarela de pago en registro, etc.
# Valores típicos: development | production (según lo que consuma tu código).
# APP_ENV=development


# -----------------------------------------------------------------------------
#  CORS — orígenes permitidos para el navegador
# -----------------------------------------------------------------------------
#
#  Desarrollo local:
#    Si omites CORS_ORIGINS, el API usa por defecto localhost en 5173 y 5174 (web / admin).
#    También puedes abrir todo el mundo (solo dev): CORS_ORIGINS=*
#
#  Producción / entorno productivo:
#    Lista explícita separada por comas: URLs exactas del web, admin y landings.
#    No uses `*` — está prohibido cuando el API detecta entorno productivo
#    (p. ej. VERCEL=1, NODE_ENV=production, APP_ENV=production).
#    Incluye previews *.vercel.app si deben llamar al API.
#
# CORS_ORIGINS=https://app.tudominio.com,https://admin.tudominio.com,https://www.tudominio.com
# CORS_ORIGINS=https://app.example.com,http://localhost:5173


# -----------------------------------------------------------------------------
#  Despliegue en Vercel (serverless)
# -----------------------------------------------------------------------------
#
#  Dashboard: Root Directory = esta carpeta (`api`). Build: `npm run build` → `dist/`.
#  El API se expone vía la función en `api/index.ts`; `vercel.json` reescribe el tráfico.
#  Rutas REST: `/health`, `/v1/…`. La variable PORT no aplica en ese modo.
#
#  Notas:
#    • `trust proxy` se activa cuando VERCEL=1 (rate limit por IP real).
#    • VERCEL=1 cuenta como entorno productivo → CORS explícito y Turnstile obligatorio.

# VERCEL=1


# -----------------------------------------------------------------------------
#  Seguridad — Cloudflare Turnstile
# -----------------------------------------------------------------------------
#
#  Si defines la clave secreta, el API exige `turnstileToken` en JSON en login workspace,
#  login plataforma y en POST críticos de registro (elegibilidad, credenciales, activate).
#
#  En entorno productivo TURNSTILE_SECRET_KEY es obligatoria: el proceso no arranca sin ella.
#  En web/admin usa la clave pública del mismo widget: VITE_TURNSTILE_SITE_KEY
#
# TURNSTILE_SECRET_KEY=


# -----------------------------------------------------------------------------
#  Proxy de confianza y rate limiting (express-rate-limit)
# -----------------------------------------------------------------------------
#
#  Los límites son por IP y por instancia (memoria). Tras nginx/caddy u otro proxy:
# TRUST_PROXY=1
#
#  Desactivar todos los límites (p. ej. pruebas locales):
# RATE_LIMIT_DISABLED=true
#
#  Login workspace (/v1/auth/login). Por defecto: 15 min, 5 intentos.
# RATE_LIMIT_AUTH_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_AUTH_LOGIN_MAX=5
#
#  Login plataforma (/v1/platform/auth/login). Misma ventana/máximo por defecto.
# RATE_LIMIT_PLATFORM_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_PLATFORM_LOGIN_MAX=5
#
#  Registro crítico (elegibilidad, verificación, credenciales, activate, paddle-complete, …).
#  Por defecto: 1 h, 40 peticiones.
# RATE_LIMIT_REGISTRATION_CRITICAL_WINDOW_MS=3600000
# RATE_LIMIT_REGISTRATION_CRITICAL_MAX=40
#
#  Resolver join por código de retrospectiva guiada (POST público, sin sesión). Por defecto: 1 h, 60/IP.
# RATE_LIMIT_GUIDED_RETRO_JOIN_RESOLVE_WINDOW_MS=3600000
# RATE_LIMIT_GUIDED_RETRO_JOIN_RESOLVE_MAX=60


# -----------------------------------------------------------------------------
#  Registro público (módulo registro-onboarding)
# -----------------------------------------------------------------------------
#
#  Correos tratados como «ya registrados» en modo provisional (coma-separada).
# REGISTRATION_PROVISIONAL_REGISTERED_EMAILS=ocupado@example.com,demo@example.com
#
#  Peppers — cambiar en producción; distintos entre OTP y contraseña del intent.
# REGISTRATION_OTP_PEPPER=cambiar-en-produccion
# REGISTRATION_INTENT_PASSWORD_PEPPER=cambiar-en-produccion
#
#  Solo desarrollo: devuelve el OTP en JSON de /verification/request (nunca en prod).
# REGISTRATION_EXPOSE_OTP_IN_RESPONSE=true
#
#  Slugs reservados además de la lista por defecto en código (coma-separada).
# REGISTRATION_RESERVED_WORKSPACE_CODES=mi-marca,interno


# -----------------------------------------------------------------------------
#  Sesión workspace (login-session)
# -----------------------------------------------------------------------------
# TTL de la sesión en ms (por defecto 7 días). Ver src/modules/login-session/README.md
# LOGIN_SESSION_TTL_MS=604800000


# -----------------------------------------------------------------------------
#  Plataforma / admin (`/v1/platform`)
# -----------------------------------------------------------------------------
#
#  Si la colección `platform_users` está vacía al arrancar, bootstrap del primer super admin.
#  También usado por `npm run seed:platform` (idempotente).
# PLATFORM_BOOTSTRAP_SUPER_ADMIN_EMAIL=agil@alineatec.com
# PLATFORM_BOOTSTRAP_SUPER_ADMIN_PASSWORD=cambiar-minimo-10-caracteres
#
#  Base URL pública del admin (invitaciones). Absoluta https://… sin query ni fragmento.
# PLATFORM_ADMIN_PUBLIC_BASE_URL=https://admin.example.com


# -----------------------------------------------------------------------------
#  Correo transaccional — Resend (src/modules/transactional-email/README.md)
# -----------------------------------------------------------------------------
#
# RESEND_API_KEY=re_...
#
# Remitente From (dominio verificado en Resend). Por defecto: agil@mail.alineatec.com
# TRANSACTIONAL_EMAIL_FROM=agil@mail.alineatec.com
#
# Sin Resend en local: no llama al proveedor (transporte noop).
# TRANSACTIONAL_EMAIL_DISABLED=true
#
# Logo en cabecera HTML de correos (URL https absoluta). Si falta: wordmark tipográfico.
# TRANSACTIONAL_EMAIL_LOGO_URL=https://app.tudominio.com/logo-white.png


# -----------------------------------------------------------------------------
#  Billing workspace — enlaces en correos y barridos (billing-seat-enforcement)
# -----------------------------------------------------------------------------
#
#  URL pública del shell web (sin barra final). Enlaces a Facturación del workspace.
#  Opcional; si falta, el texto orienta a abrir Facturación desde el menú.
#  También se usa para enlaces en correo de restablecimiento de contraseña y bienvenida al añadir miembro al workspace.
# WORKSPACE_APP_PUBLIC_BASE_URL=https://app.example.com
#
#  Caducidad del enlace de restablecimiento (ms). Por defecto 1 h; mínimo 60_000; máximo 24 h.
# PASSWORD_RESET_TTL_MS=3600000
#
#  Rate limit POST /v1/auth/password-reset/request (ventana y máximo por IP).
# RATE_LIMIT_PASSWORD_RESET_REQUEST_WINDOW_MS=900000
# RATE_LIMIT_PASSWORD_RESET_REQUEST_MAX=5
#
#  Rate limit POST /v1/auth/password-reset/confirm.
# RATE_LIMIT_PASSWORD_RESET_CONFIRM_WINDOW_MS=3600000
# RATE_LIMIT_PASSWORD_RESET_CONFIRM_MAX=20
#
#  Diagnóstico si POST /v1/auth/password-reset/request responde 200 pero no llega correo:
#    • Logs: busca `password_reset_no_registered_user_for_email` (no hay cuenta con ese email en BD),
#      `password_reset_skipped_missing_workspace_app_public_base_url` (falta WORKSPACE_APP_PUBLIC_BASE_URL),
#      `password_reset_email_misconfigured` | `password_reset_email_failed` | `transactional_email_failed`,
#      o éxito `transactional_email_sent` con templateKey registered_user_password_reset.
#    • Resend: dominio de `TRANSACTIONAL_EMAIL_FROM` verificado; en cuentas nuevas a veces solo llega a correos de prueba verificados.
#
#  Intervalo entre barridos (ms): suspensión tras gracia, avisos. Por defecto 6 h (21600000).
#  Usa 0 para desactivar el temporizador (solo webhooks / GET billing/state).
# BILLING_NOTIFICATION_SWEEP_MS=21600000


# -----------------------------------------------------------------------------
#  Registro comercial y Paddle (payment-gateway-policy + Paddle Billing)
# -----------------------------------------------------------------------------
#
#  Si en producción el checkout no está permitido, el API responde 403 en mutaciones bajo
#  POST /v1/public/registration/* (salvo /commercial-quote). Ver payment-gateway-policy.ts
# PAYMENT_GATEWAY_PROVIDER=paddle
# PAYMENT_GATEWAY_MODE=disabled
# PAYMENT_GATEWAY_STATUS=inactive
#
#  Webhook Paddle Billing — POST /v1/integrations/paddle/webhooks (body JSON crudo).
#
#  IMPORTANTE — Dos campos distintos en Paddle:
#    • URL de destino: la configurás en el dashboard (Notifications), ej.
#      https://api.agil.alineatec.com/v1/integrations/paddle/webhooks
#    • Secreto (esta variable): el "endpoint_secret_key" que Paddle muestra para ESE destino
#      (cadena larga tipo pdl_… / secreto; NO pegues la URL aquí).
#
#  Sin comillas envolventes; la URL aquí → invalid_signature y/o el API no arranca (validación).
# PADDLE_WEBHOOK_SECRET=
# Ventana anti-replay sobre Paddle-Signature (segundos; por defecto 600).
# PADDLE_WEBHOOK_TS_TOLERANCE_SECONDS=600
#
#  Confirmación de pago en registro (mismo JSON en cualquiera de las rutas alias):
#    /v1/public/registration/payment/paddle-complete
#    /v1/public/registration/payments/paddle-complete
#    /v1/public/registration-payment/paddle-complete
#
#  Clave API servidor (sandbox_* / live_* o pdl_sdbx_apikey_* / pdl_live_apikey_*).
#  El prefijo elige sandbox-api vs api.paddle.com. No uses el client token de Paddle.js.
#  Si la clave es de permisos restringidos: incluye customer_portal_session.write (portal de facturación / POST portal-sessions).
# PADDLE_API_KEY=
#
#  Catálogo Paddle — modelo vigente (Estándar $6/licencia, Profesional $12/licencia, sin mínimo):
#  Si los 2 IDs tier mensuales están definidos, checkout/webhooks usan qty = licencias contratadas.
# PADDLE_PRICE_ESTANDAR_LICENSE_MONTHLY=
# PADDLE_PRICE_PROFESIONAL_LICENSE_MONTHLY=
#  Alias legado (opcional): PADDLE_PRICE_TEAM_LICENSE_MONTHLY / PADDLE_PRICE_PRO_LICENSE_MONTHLY
#
#  Modelo legado (suscripciones históricas: base 3 + addon) — omitir si usas solo tier:
# PADDLE_PRICE_INDIVIDUAL_MONTHLY=
# PADDLE_PRICE_TEAM_BASE_MONTHLY=
# PADDLE_PRICE_ADDITIONAL_SEAT_MONTHLY=


# -----------------------------------------------------------------------------
#  Sentry (errores y trazas)
# -----------------------------------------------------------------------------
#
#  Envío solo si el despliegue se considera productivo (APP_ENV / SENTRY_ENVIRONMENT / NODE_ENV).
#  Tags: alinea_service=api, runtime=node
#
# SENTRY_DSN=https://...@....ingest.de.sentry.io/...
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
#
#  Forzar reporte desde máquina local (nunca en producción):
# SENTRY_REPORT_IN_DEV=true


# -----------------------------------------------------------------------------
#  Solo desarrollo — rutas de diagnóstico (no activar en producción)
# -----------------------------------------------------------------------------
#
#  Expone GET /debug/sentry/throw | /capture | /message
#  Valores: true | 1 | yes. Sin esto, esas rutas responden 403 con pista JSON.
# SENTRY_DEBUG_ROUTES=true
